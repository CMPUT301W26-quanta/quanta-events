<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.QuantaEvents" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item>-->
        <item name="colorPrimary">@color/color_light</item>
        <item name="colorPrimaryDark">@color/color_dark</item>
        <item name="colorAccent">@color/color_dark_purple</item>
    </style>

    <style name="RoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ThemeOverlay.QuantaEvents.DatePicker" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorSurface">@color/color_light_gray</item>
        <item name="colorOnSurface">@color/text_color</item>
        <item name="colorOnSurfaceVariant">@color/text_color</item>
        <item name="colorPrimary">@color/color_dark_purple</item>
        <item name="colorOnPrimary">@color/color_light</item>
    </style>

    <style name="ThemeOverlay.QuantaEvents.TimePicker" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorSurface">@color/color_light_gray</item>
        <item name="colorOnSurface">@color/text_color</item>
        <item name="colorOnSurfaceVariant">@color/text_color</item>
        <item name="colorPrimary">@color/color_dark_purple</item>
        <item name="colorOnPrimary">@color/color_light</item>
    </style>


</resources>