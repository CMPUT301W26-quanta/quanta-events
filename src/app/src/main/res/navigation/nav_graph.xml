<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/registerFragment">

    <fragment
        android:id="@+id/registerFragment"
        android:name="ca.quanta.quantaevents.fragments.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerfragment_to_homefragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="ca.quanta.quantaevents.fragments.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_informationFragment"
            app:destination="@id/informationFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/informationFragment"
        android:name="ca.quanta.quantaevents.fragments.InformationFragment"
        android:label="fragment_information"
        tools:layout="@layout/fragment_information" />

    <fragment
        android:id="@+id/accountFragment"
        android:name="ca.quanta.quantaevents.fragments.AccountFragment"
        android:label="fragment_account"
        tools:layout="@layout/fragment_account">
        <action
            android:id="@+id/action_accountfragment_to_registerfragment"
            app:destination="@id/registerFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_accountfragment_to_homefragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/adminpanelFragment"
        android:name="ca.quanta.quantaevents.fragments.AdminPanelFragment"
        android:label="fragment_admin_panel"
        tools:layout="@layout/fragment_admin_panel">
        <action
            android:id="@+id/action_adminpanelFragment_to_admineventbrowserFragment"
            app:destination="@id/admineventbrowserFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_adminpanelFragment_to_adminprofilebrowserFragment"
            app:destination="@id/adminprofilebrowserFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_admineventbrowserfragment_to_eventedetailsfragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_adminpanelFragment_to_adminImageBrowserFragment"
            app:destination="@id/adminImageBrowserFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/admineventbrowserFragment"
        android:name="ca.quanta.quantaevents.fragments.AdminEventBrowserFragment"
        android:label="fragment_admin_event_browser_panel"
        tools:layout="@layout/fragment_admin_event_browser">
        <action
            android:id="@+id/action_admineventbrowserfragment_to_eventdetailsfragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/adminprofilebrowserFragment"
        android:name="ca.quanta.quantaevents.fragments.AdminProfileBrowserFragment"
        android:label="fragment_admin_profile_browser_panel"
        tools:layout="@layout/fragment_admin_profile_browser">
        <action
            android:id="@+id/action_adminprofilebrowserFragment_to_adminNotificationHistoryFragment"
            app:destination="@id/adminNotificationHistoryFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/eventdashboardFragment"
        android:name="ca.quanta.quantaevents.fragments.EventDashboardFragment"
        android:label="fragment_event_dashboard"
        tools:layout="@layout/fragment_event_dashboard">
        <action
            android:id="@+id/action_eventdashboardfragment_to_eventedetailsfragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_eventdashboardFragment_to_eventEditorFragment"
            app:destination="@id/eventEditorFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/eventEditorFragment"
        android:name="ca.quanta.quantaevents.fragments.EventCreateEditorFragment"
        android:label="fragment_event_editor"
        tools:layout="@layout/fragment_event_create_editor">
        <argument
            android:name="eventId"
            app:argType="java.util.UUID"
            app:nullable="true" />
    </fragment>


    <fragment
        android:id="@+id/eventManagerFragment"
        android:name="ca.quanta.quantaevents.fragments.EventManagerFragment"
        android:label="fragment_event_manager"
        tools:layout="@layout/fragment_event_manager">
        <action
            android:id="@+id/action_eventmanagerfragment_to_createeditorfragment"
            app:destination="@id/eventEditorFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_eventmanagerfragment_to_showqrfragment"
            app:destination="@id/showQRFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_eventmanagerfragment_to_eventwaitinglistfragment"
            app:destination="@id/eventWaitingListFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_eventmanagerfragment_to_sendnotificationfragment"
            app:destination="@id/eventNotificationEditorFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
        <argument
            android:name="isDrawn"
            app:argType="boolean" />
        <action
            android:id="@+id/action_eventManagerFragment_to_eventInviteFragment"
            app:destination="@id/eventInviteFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <argument
            android:name="isPrivate"
            app:argType="boolean" />
        <action
            android:id="@+id/action_eventManagerFragment_to_inviteCoOrganizerFragment"
            app:destination="@id/invite_co_organizer_fragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/invite_co_organizer_fragment"
        android:name="ca.quanta.quantaevents.fragments.InviteCoOrganizerFragment"
        android:label="fragment_invite_co_organizer"
        tools:layout="@layout/fragment_invite_co_organizer">
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
    </fragment>

    <fragment
        android:id="@+id/eventWaitingListFragment"
        android:name="ca.quanta.quantaevents.fragments.EventWaitingListFragment"
        android:label="fragment_event_waiting_list"
        tools:layout="@layout/fragment_event_waitlist">
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
    </fragment>

    <fragment
        android:id="@+id/eventNotificationEditorFragment"
        android:name="ca.quanta.quantaevents.fragments.EventNotificationEditorFragment"
        android:label="fragment_event_notification_editor"
        tools:layout="@layout/fragment_notification_editor">
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
    </fragment>

    <fragment
        android:id="@+id/showQRFragment"
        android:name="ca.quanta.quantaevents.fragments.ShowQRFragment"
        android:label="fragment_show_qr"
        tools:layout="@layout/fragment_show_qr">
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
    </fragment>

    <fragment
        android:id="@+id/entrantEventListFragment"
        android:name="ca.quanta.quantaevents.fragments.EntrantEventListFragment"
        android:label="fragment_entrant_event_list"
        tools:layout="@layout/fragment_entrant_event_list">
        <action
            android:id="@+id/action_entranteventlist_to_entranteventhistoryfragment"
            app:destination="@id/entrantEventHistoryFragment"
            app:popUpToInclusive="false"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_entranteventlist_to_entranteventbrowserfragment"
            app:destination="@id/eventBrowserFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_entranteventlist_to_eventdetailsfragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/eventBrowserFragment"
        android:name="ca.quanta.quantaevents.fragments.EntrantEventBrowserFragment"
        android:label="fragment_entrant_event_browser"
        tools:layout="@layout/fragment_entrant_event_browser">
        <action
            android:id="@+id/action_entranteventbrowserfragment_to_eventfilterfragment"
            app:destination="@id/eventFilterFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_entranteventbrowserfragment_to_eventqrcodefragment"
            app:destination="@id/eventQRCodeFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <action
            android:id="@+id/action_eventBrowserFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

    </fragment>

    <fragment
        android:id="@+id/eventQRCodeFragment"
        android:name="ca.quanta.quantaevents.fragments.EventQRCodeFragment"
        android:label="fragment_event_qr_code"
        tools:layout="@layout/fragment_event_qr_code">
        <action
            android:id="@+id/action_eventQRCodeFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim"
            app:popUpTo="@id/eventBrowserFragment" />
    </fragment>

    <fragment
        android:id="@+id/eventFilterFragment"
        android:name="ca.quanta.quantaevents.fragments.EventFilterFragment"
        android:label="fragment_event_filter"
        tools:layout="@layout/fragment_event_filter" />

    <fragment
        android:id="@+id/entrantEventHistoryFragment"
        android:name="ca.quanta.quantaevents.fragments.EntrantEventHistoryFragment"
        android:label="fragment_entrant_event_history"
        tools:layout="@layout/fragment_entrant_event_history">
        <action
            android:id="@+id/action_entrantEventHistoryFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/eventDetailsFragment"
        android:name="ca.quanta.quantaevents.fragments.EventDetailsFragment"
        android:label="fragment_event_details"
        tools:layout="@layout/fragment_event_details">
        <action
            android:id="@+id/action_eventdetailsfragment_to_eventmanagerfragment"
            app:destination="@id/eventManagerFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
        <argument
            android:name="fromAdmin"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <action
        android:id="@+id/action_global_homeFragment"
        app:destination="@id/homeFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim"
        app:popEnterAnim="@anim/nav_default_pop_enter_anim"
        app:popExitAnim="@anim/nav_default_pop_exit_anim"
        app:popUpTo="@id/nav_graph" />
    <action
        android:id="@+id/action_global_eventdashboardFragment"
        app:destination="@id/eventdashboardFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim"
        app:popEnterAnim="@anim/nav_default_pop_enter_anim"
        app:popExitAnim="@anim/nav_default_pop_exit_anim"
        app:popUpTo="@id/nav_graph" />
    <action
        android:id="@+id/action_global_adminpanelFragment"
        app:destination="@id/adminpanelFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim"
        app:popEnterAnim="@anim/nav_default_pop_enter_anim"
        app:popExitAnim="@anim/nav_default_pop_exit_anim"
        app:popUpTo="@id/nav_graph" />
    <action
        android:id="@+id/action_global_accountFragment"
        app:destination="@id/accountFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim"
        app:popEnterAnim="@anim/nav_default_pop_enter_anim"
        app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    <action
        android:id="@+id/action_global_entranteventlistFragment"
        app:destination="@id/entrantEventListFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim"
        app:popEnterAnim="@anim/nav_default_pop_enter_anim"
        app:popExitAnim="@anim/nav_default_pop_exit_anim"
        app:popUpTo="@id/nav_graph" />
    <fragment
        android:id="@+id/adminNotificationHistoryFragment"
        android:name="ca.quanta.quantaevents.fragments.AdminNotificationHistoryFragment"
        android:label="fragment_android_notifcation_history_panel"
        tools:layout="@layout/fragment_admin_notification_history">
        <argument
            android:name="profileId"
            app:argType="java.util.UUID"
            app:nullable="false" />
    </fragment>
    <action
        android:id="@+id/action_global_registerFragment"
        app:destination="@id/registerFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim"
        app:popEnterAnim="@anim/nav_default_pop_enter_anim"
        app:popExitAnim="@anim/nav_default_pop_exit_anim"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />
    <fragment
        android:id="@+id/adminImageBrowserFragment"
        android:name="ca.quanta.quantaevents.fragments.AdminImageBrowserFragment"
        android:label="AdminImageBrowserFragment"
        tools:layout="@layout/fragment_admin_image_browser"/>
    <fragment
        android:id="@+id/eventInviteFragment"
        android:name="ca.quanta.quantaevents.fragments.EventInviteFragment"
        android:label="fragment_event_invite"
        tools:layout="@layout/fragment_event_invite" >
        <argument
            android:name="eventId"
            app:argType="java.util.UUID" />
    </fragment>

</navigation>
