<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/testFragmentOne">

    <fragment
        android:id="@+id/testFragmentOne"
        android:name="ca.quanta.quantaevents.fragments.TestFragmentOne"
        android:label="fragment_test_one"
        tools:layout="@layout/fragment_test_one">
        <action
            android:id="@+id/action_testFragmentOne_to_testFragmentTwo"
            app:destination="@id/testFragmentTwo" />
        <action
            android:id="@+id/action_testFragmentOne_to_eventList"
            app:destination="@id/eventList" />
    </fragment>
    <action
        android:id="@+id/action_global_testFragmentOne"
        app:destination="@id/testFragmentOne"
        app:popUpTo="@id/nav_graph" />
    <fragment
        android:id="@+id/testFragmentTwo"
        android:name="ca.quanta.quantaevents.fragments.TestFragmentTwo"
        android:label="fragment_test_two"
        tools:layout="@layout/fragment_test_two" />
    <fragment
        android:id="@+id/eventList"
        android:name="ca.quanta.quantaevents.fragments.EventList"
        android:label="fragment_event_list"
        tools:layout="@layout/fragment_event_list" />
</navigation>