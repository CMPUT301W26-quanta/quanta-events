<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/edit_details_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="Edit Event Details"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/share_qr_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="Share QR Code"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/view_wait_list_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="View Waiting List"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/view_wait_list_map_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="View Waiting List Map"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/send_notification_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="Send Notification"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/draw_lottery_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_green"
                android:text="Draw Lottery Participants"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/back_button"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="@color/color_dark_purple"
        android:text="Back"
        android:textColor="@color/text_color"
        android:textAlignment="center"
        app:cornerRadius="12dp"
        app:strokeColor="@color/border"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
