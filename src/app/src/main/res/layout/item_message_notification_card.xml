<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/border"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="start"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingVertical="2dp"
            android:gravity="start"
            android:layout_weight="1">

            <!-- Event Name -->
            <TextView
                android:id="@+id/notification_event_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_color"
                android:text="Loading event name..."
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Event icon -->
            <ImageView
                android:id="@+id/icon_event"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/material_symbols_event_outline" />

            <!-- Dismiss icon -->
            <ImageView
                android:id="@+id/icon_dismiss"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/material_symbols_delete" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Loading notification title..."
            android:textSize="16sp"
            android:textColor="@color/text_color"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Message -->
        <TextView
            android:id="@+id/notification_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Loading notification message..."
            android:textSize="12sp"
            android:textColor="@color/text_color" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
