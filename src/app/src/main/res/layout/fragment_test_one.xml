<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_light"
    tools:context=".fragments.TestFragmentOne">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="" />

    <Button
        android:id="@+id/info_button"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_margin="12dp"
        android:backgroundTint="@color/color_dark_purple"
        android:drawableBottom="@android:drawable/ic_menu_info_details"
        android:insetLeft="4dp"
        android:insetRight="4dp"
        app:cornerRadius="10dp"
        app:icon="@drawable/material_symbols_info_outline"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@color/color_dark"
        app:strokeColor="@color/color_dark"
        app:strokeWidth="2dp" />

    <Button
        android:id="@+id/account_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@color/color_light_gray"
        android:text="Account"
        app:strokeColor="@color/color_dark"
        app:strokeWidth="2dp" />


</LinearLayout>