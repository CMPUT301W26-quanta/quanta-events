<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Filter + QR Buttons -->
    <LinearLayout
        android:id="@+id/layout_top_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/filter_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:backgroundTint="@color/color_dark_purple"
            android:insetLeft="4dp"
            android:insetRight="4dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/material_symbols_filter_alt_outline"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/color_dark"
            app:iconSize="28dp"
            app:strokeColor="@color/color_dark"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/qr_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:backgroundTint="@color/color_dark_purple"
            android:insetLeft="4dp"
            android:insetRight="4dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/material_symbols_qr_code_outline"
            app:iconGravity="textStart"
            app:iconSize="28dp"
            app:iconPadding="0dp"
            app:iconTint="@color/color_dark"
            app:strokeColor="@color/color_dark"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <!-- Events RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/events_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="vertical"
        android:overScrollMode="ifContentScrolls"
        android:fadingEdge="vertical"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="20dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_buttons"
        app:layout_constraintBottom_toTopOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Back Button -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="20dp"
        android:text="Back"
        android:backgroundTint="@color/color_light_purple"
        android:textColor="@color/text_color"
        app:cornerRadius="12dp"
        app:strokeColor="@color/border"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>