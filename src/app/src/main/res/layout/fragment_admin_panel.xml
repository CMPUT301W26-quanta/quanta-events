<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/admin_browse_events_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="Browse Events"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/admin_browse_profiles_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="Browse Profiles"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

            <Button
                android:id="@+id/admin_browse_images_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/color_light_purple"
                android:text="Browse Images"
                android:textColor="@color/text_color"
                android:textSize="16sp"
                android:textAlignment="center"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="2dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
