<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.HomeFragment">

    <ImageButton
        android:id="@+id/info_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_icon_container"
        android:contentDescription="Info"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/material_symbols_info_outline" />

    <!-- INVITE Notification RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/invite_notifications_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="true"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="20dp"
        android:overScrollMode="ifContentScrolls"
        android:requiresFadingEdge="vertical"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toTopOf="@id/lottery_notifications_recycler_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_button" />

    <!-- LOTTERY Notification RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lottery_notifications_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="true"
        android:scrollbars="vertical"
        android:fadingEdge="vertical"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="20dp"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintTop_toBottomOf="@id/invite_notifications_recycler_view"
        app:layout_constraintBottom_toTopOf="@id/message_notifications_recycler_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- MESSAGE Notification RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/message_notifications_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="true"
        android:scrollbars="vertical"
        android:fadingEdge="vertical"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="20dp"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintTop_toBottomOf="@id/lottery_notifications_recycler_view"
        app:layout_constraintBottom_toTopOf="@id/coInvite_notifications_recycler_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- coInvite Notification RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/coInvite_notifications_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="true"
        android:scrollbars="vertical"
        android:fadingEdge="vertical"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="20dp"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintTop_toBottomOf="@id/message_notifications_recycler_view"
        app:layout_constraintBottom_toTopOf="@id/menu_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/menu_container"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="64dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/nav_home"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_icon_container"
            android:contentDescription="Home"
            android:padding="10dp"
            app:srcCompat="@drawable/material_symbols_home_outline" />

        <ImageButton
            android:id="@+id/nav_security"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_icon_container"
            android:contentDescription="Security"
            android:padding="10dp"
            app:srcCompat="@drawable/material_symbols_security" />

        <ImageButton
            android:id="@+id/nav_account"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_icon_container"
            android:contentDescription="Account"
            android:padding="10dp"
            app:srcCompat="@drawable/material_symbols_person_outline" />

        <ImageButton
            android:id="@+id/nav_events"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_icon_container"
            android:contentDescription="Events"
            android:padding="10dp"
            app:srcCompat="@drawable/material_symbols_event_list_outline" />

        <ImageButton
            android:id="@+id/nav_dashboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_container"
            android:contentDescription="Dashboard"
            android:padding="10dp"
            app:srcCompat="@drawable/material_symbols_dashboard_outline" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
