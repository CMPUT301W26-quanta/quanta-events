<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- History + Search buttons -->
    <LinearLayout
        android:id="@+id/layout_top_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/history_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:backgroundTint="@color/color_dark_purple"
            android:insetLeft="4dp"
            android:insetRight="4dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/material_symbols_history"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/color_dark"
            app:iconSize="28dp"
            app:strokeColor="@color/color_dark"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/search_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:backgroundTint="@color/color_dark_purple"
            android:insetLeft="4dp"
            android:insetRight="4dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/material_symbols_search_outline"
            app:iconGravity="textStart"
            app:iconSize="28dp"
            app:iconPadding="0dp"
            app:iconTint="@color/color_dark"
            app:strokeColor="@color/color_dark"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <!-- Events RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/events_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintTop_toBottomOf="@id/layout_top_buttons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>